{
	"root": true,
	"ignorePatterns": ["projects/**/*"],
	"overrides": [
		{
			"files": ["*.ts"],
			"parser": "@typescript-eslint/parser",
			"parserOptions": {
				"project": ["tsconfig.json", "e2e/tsconfig.json"],
				"createDefaultProgram": true
			},
			"extends": [
				"plugin:@angular-eslint/recommended",
				"plugin:@angular-eslint/template/process-inline-templates",
				"eslint:recommended",
				"plugin:@typescript-eslint/recommended",
				"plugin:@typescript-eslint/recommended-requiring-type-checking",
				"plugin:prettier/recommended"
			],
			"rules": {
				"eqeqeq": ["warn", "always", { "null": "ignore" }],
				"no-restricted-imports": "warn",
				"no-unused-vars": "off",
				"max-depth": 1,
				"sort-imports": [
					"warn",
					{
						"ignoreCase": true,
						"ignoreDeclarationSort": true,
						"ignoreMemberSort": false,
						"memberSyntaxSortOrder": ["none", "all", "multiple", "single"],
						"allowSeparatedGroups": true
					}
				],
				"import/namespace": ["error", { "allowComputed": true }],
				"import/order": [
					"warn",
					{
						"groups": ["internal", "unknown", "external", ["builtin", "sibling", "parent"], "index"],
						"pathGroups": [
							{
								"pattern": "@angular/**",
								"group": "internal"
							},
							{
								"pattern": "@angular",
								"group": "internal"
							},
							{
								"pattern": "rxjs",
								"group": "unknown"
							},
							{
								"pattern": "rxjs/**",
								"group": "unknown"
							},
							{
								"pattern": "uuid",
								"group": "unknown"
							},
							{
								"pattern": "ng-**",
								"group": "unknown"
							},
							{
								"pattern": "ts-simple-nameof",
								"group": "unknown"
							},
							{
								"pattern": "typescript-guid",
								"group": "unknown"
							},
							{
								"pattern": "date-fns",
								"group": "unknown"
							},
							{
								"pattern": "@dynamic-mapper/**",
								"group": "unknown"
							},
							{
								"pattern": "lodash",
								"group": "unknown",
								"position": "before"
							},
							{
								"pattern": "@ngxs/**",
								"group": "unknown"
							},
							{
								"pattern": "@internal-library",
								"group": "builtin"
							}
						],
						"pathGroupsExcludedImportTypes": ["type", "object"],
						"newlines-between": "always",
						"alphabetize": {
							"order": "asc",
							"caseInsensitive": true
						}
					}
				],
				"@angular-eslint/component-selector": [
					"error",
					{
						"type": "element",
						"prefix": ["app", "currency-rates", ""],
						"style": "kebab-case"
					}
				],
				"@angular-eslint/directive-selector": [
					"error",
					{
						"type": "attribute",
						"prefix": "app",
						"style": "camelCase"
					}
				],
				"@angular-eslint/no-input-rename": "warn",
				"@angular-eslint/no-output-native": "warn",
				"@angular-eslint/no-output-rename": "warn",
				"@angular-eslint/prefer-inject": "warn",
				"@angular-eslint/prefer-standalone": "off",
				"@typescript-eslint/no-empty-function": ["warn", { "allow": ["constructors"] }],
				"@typescript-eslint/no-explicit-any": "warn",
				"@typescript-eslint/no-unused-vars": [
					"warn",
					{
						"argsIgnorePattern": "^_",
						"caughtErrorsIgnorePattern": "^_",
						"varsIgnorePattern": "^_"
					}
				]
			}
		},
		{
			"files": ["*.html"],
			"plugins": ["@typescript-eslint", "prettier", "import"],
			"settings": {
				"import/internal-regex": "@angular/**",
				"import/external-module-folders": ["node_modules"],
				"import/parsers": {
					"@typescript-eslint/parser": [".ts"]
				},
				"import/resolver": {
					"alias": true,
					"typescript": {
						"alwaysTryTypes": true,
						"project": "./tsconfig.json"
					}
				}
			},
			"extends": [
				"plugin:import/typescript",
				"plugin:import/errors",
				"plugin:import/warnings",
				"plugin:import/recommended",
				"plugin:@angular-eslint/template/recommended",
				"plugin:prettier/recommended",
				"eslint:recommended",
				"plugin:@typescript-eslint/recommended",
				"plugin:prettier/recommended"
			],
			"rules": {
				"@angular-eslint/template/alt-text": "warn",
				"@angular-eslint/template/button-has-type": "warn",
				"@angular-eslint/template/click-events-have-key-events": "warn",
				"@angular-eslint/template/eqeqeq": "warn",
				"@angular-eslint/template/interactive-supports-focus": "warn",
				"@angular-eslint/template/label-has-associated-control": "warn",
				"@angular-eslint/template/no-call-expression": "warn",
				"@angular-eslint/template/no-negated-async": "warn",
				"@angular-eslint/template/valid-aria": "warn"
			}
		}
	]
}
