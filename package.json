{
  "name": "h-budget",
  "version": "0.214.68",
  "private": true,
  "scripts": {
    "ng": "ng",
    "prepare": "husky",
    "start": "nx serve --watch --open --ssl true --configuration=development",
    "start:prod": "nx serve --open --port=4300 --ssl true --configuration=production",
    "start:debug": "nx serve --configuration=development --verbose --inspect",
    "build": "nx build --configuration=development --verbose",
    "build:prod": "nx build h-budget --configuration=production --verbose",
    "build:prod:deploy": "npm run build:prod && npm run sentry:sourcemaps",
    "watch": "nx build --watch --configuration=development",
    "test": "nx test --code-coverage --verbose",
    "test:ci": "nx test --watch=false --code-coverage --source-map=false --browsers=ChromiumNoSandbox",
    "test:watch": "nx test --watch=true",
    "lint": "nx lint",
    "lint:fix": "nx lint --fix --verbose",
    "lint:css": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "format": "prettier --write src/**/*.{js,ts,css,html,scss}",
    "eslint": "eslint --cache",
    "eslint:fix": "eslint --cache --fix --ext .js,.ts src",
    "eslint:config": "eslint --print-config ./.eslintrc.json",
    "validate": "npm run lint && npm run test",
    "sonar": "sonar-scanner",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "security-check": "npm audit --audit-level=moderate",
    "clean": "rimraf node_modules package-lock.json .nx dist coverage",
    "clean:all": "npm run clean && rimraf .angular .cache",
    "reinstall": "npm run clean && npm i",
    "rebuild": "npm run clean && npm i && npm dedupe && npm run build",
    "rebuild:prod": "npm run clean && npm i --omit=dev && rimraf dist && npm run build:prod",
    "major-update": "npx npm-check-updates -u",
    "minor-update": "npx npm-check-updates --peer -u",
    "deps:update:patch:safe": "npx npm-check-updates --target patch --reject '/^@angular($|\\/)|^@angular-devkit($|\\/)|^@angular-eslint($|\\/)|^@nx($|\\/)|^nx$|^@schematics\\/angular$/' -u && npm install",
    "deps:update:minor:safe": "npx npm-check-updates --target minor --reject '/^@angular($|\\/)|^@angular-devkit($|\\/)|^@angular-eslint($|\\/)|^@nx($|\\/)|^nx$|^@schematics\\/angular$/' -u && npm install",
    "deps:update:patch": "npm run deps:update:patch:safe",
    "deps:update:minor": "npm run deps:update:minor:safe",
    "deps:apply": "npm install",
    "update:deps": "npm update && npm i",
    "update:soft": "npx npm-check-updates --target minor && npm i && npm update",
    "update:hard": "npx npm-check-updates -u && npm i && npm update && npm audit fix",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist/h-budget && sentry-cli sourcemaps upload ./dist/h-budget",
    "ci:build": "npm run lint && npm run test:ci && npm run build:prod",
    "ci:full": "npm run security-check && npm run lint && npm run test:ci && npm run build:prod:deploy",
    "nx:graph": "nx graph",
    "nx:affected": "nx affected --target=build",
    "deps:check": "npx npm-check-updates --target minor",
    "ci:verify": "npm run lint && npm run test:ci && npm run build:prod",
    "preinstall": "node -e \"const v=require('child_process').execSync('npm -v').toString().trim(); if (parseInt(v.split('.')[0],10) < 11) { console.error('❌ npm v11+ required. Current:', v); process.exit(1); }\""
  },
  "dependencies": {
    "@angular/animations": "^20.3.17",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "@dynamic-mapper/angular": "^1.1.1",
    "@dynamic-mapper/mapper": "^1.10.4",
    "@microsoft/signalr": "^10.0.0",
    "@ngxs/devtools-plugin": "^20.1.0",
    "@ngxs/logger-plugin": "^20.1.0",
    "@ngxs/store": "^20.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone-peer-dep": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-document-load": "^0.63.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.62.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/angular": "^10.56.0",
    "@sentry/cli": "^2.58.6",
    "@sentry/tracing": "^7.120.4",
    "@types/lodash": "^4.17.24",
    "@types/uuid": "^11.0.0",
    "apexcharts": "^5.14.0",
    "date-fns": "^4.4.0",
    "downsample": "^1.4.0",
    "flag-icons": "^7.5.0",
    "immer": "^10.2.0",
    "lodash": "^4.18.1",
    "material-design-icons": "^3.0.1",
    "ng-apexcharts": "~2.4.0",
    "rimraf": "^6.1.3",
    "rxjs": "~7.8.2",
    "stylelint": "^16.26.1",
    "ts-evaluator": "^2.0.0",
    "ts-simple-nameof": "^1.3.3",
    "tslib": "^2.8.1",
    "typescript-guid": "^1.0.3",
    "uuid": "^13.0.2",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.20",
    "@angular-devkit/core": "^20.3.20",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.17",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@nx/angular": "^22.5.4",
    "@nx/eslint": "^22.5.4",
    "@nx/workspace": "^22.5.4",
    "@schematics/angular": "^20.3.20",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^24.13.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jasmine-core": "~5.13.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "karma-sonarqube-reporter": "^1.4.0",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.6",
    "npm-run-all": "^4.1.5",
    "nx": "^22.5.4",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "sonarqube-scanner": "^4.3.6",
    "stylelint-prettier": "^5.0.3",
    "typescript": "~5.9.3"
  },
  "nx": {},
  "overrides": {
    "ora": "5.4.1"
  },
  "packageManager": "npm",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
